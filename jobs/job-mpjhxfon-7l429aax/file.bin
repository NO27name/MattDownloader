<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Download</title>
  </head>
  <style>
    body {
      background-color: #f0f8fe;
      font-family: "PingFang SC";
      margin: 0;
      height: 100vh;
      min-height: 600px;
    }
    img {
      user-select: none;
      pointer-events: none;
    }
    .main {
      height: -webkit-fill-available;
      width: 928px;
      margin: 0 auto;
      padding: 96px 48px;
      position: relative;
    }
    .logo {
      margin-bottom: 150px;
    }
    #count {
      color: #19a8ff;
      font-size: 64px;
      font-style: normal;
      font-weight: 600;
      margin-bottom: 36px;
    }
    #msg {
      color: #000;
      font-size: 32px;
      font-weight: 600;
    }
    #download {
      margin-top: 36px;
      display: inline-flex;
      padding: 12px 36px;
      justify-content: center;
      align-items: center;
      gap: 10px;
      border-radius: 62px;
      border: 1px solid var(--1-eaaff, #1eaaff);
      background: #1eaaff;
      color: #fff;
      font-size: 32px;
      font-weight: 600;
      letter-spacing: -0.4px;
      cursor: pointer;
      visibility: hidden;
    }
    .sucai {
      position: absolute;
      bottom: 80px;
      right: 0;
    }
    .footer {
      color: var(---H3, #939393);
      left: 50%;
      transform: translateX(-50%);
      font-weight: 400;
      font-size: 12px;
      position: absolute;
      bottom: 32px;
    }
  </style>
  <body>
    <section class="main">
      <img src="/assets/LOGO.png" alt="logo" class="logo" />
      <section id="count"></section>
      <section id="msg"></section>
      <button id="download"></button>
      <img src="/assets/Sucai.png" alt="sucai" class="sucai" />
      <section class="footer"></section>
    </section>
    <script>
      const msgs = {
        begin: {
          en: "Your download will start shortly...",
          zh: "您的下载即将开始..."
        },
        end: {
          en: `Thank you for downloading!\nIf the download doesn't start automatically, click the button below.`,
          zh: `感谢您下载！\n如果下载没有自动开始，请点击下方的按钮。`
        },
        error: {
          en: `Sorry, we can’t proceed your download request.\n\nThere is a risk in the current environment to block the download, please try again later or contact\n`,
          zh: `抱歉，我们无法处理您的下载请求。\n\n当前环境存在风险，已阻止下载。请稍后重试或关注【童心制物售后】微信公众号获取帮助。`
        },
        download: {
          en: "Download Manually",
          zh: "手动下载"
        },
        email: {
          en: "service@makeblock.com",
          zh: ""
        },
        copyright: {
          en: "Copyright © 2024 Makeblock Europe B.V. - All Rights Reserved.",
          zh: "Copyright © 2024 Makeblock 童心制物 版权所有 粤ICP备19047421号-1 深圳市创客工场科技有限公司"
        },
        workerError:{
          en: "Your browser doesn't support web workers.",
          zh: "您的浏览器不支持 Web workers。"
        }
      };

      const lang = ['zh-CN', 'zh'].includes(navigator.language) ? 'zh' : 'en';
      let timer = null;
      let count = 5;
      document.querySelector("#msg").innerHTML = msgs.begin[lang];
      document.querySelector("#download").innerHTML = msgs.download[lang];
      document.querySelector(".footer").innerHTML = msgs.copyright[lang];

      function setTimer() {
        document.querySelector("#count").innerHTML = `${count}`;
        timer = setInterval(() => {
          count--;
          if (count === 0) {
            clearInterval(timer);
            timer = null;
          }
          document.querySelector("#count").innerHTML = `${count}`;
        }, 1000);
      }

      function setDownload(url) {
        clearInterval(timer);
        timer = null;
        document.querySelector("#count").style.display = "none";
        if (url) {
          document.querySelector("#msg").innerHTML = msgs.end[lang];
          document.querySelector("#download").style.visibility = "visible";
          document.querySelector("#download").onclick = () => download(url);
          download(url);
        } else {
          document.querySelector("#msg").innerHTML =
            `<span style="font-size: 64px;font-weight: 600;display: block;">: (</span>` +
            msgs.error[lang] +
            `<span style="color: #19A8FF;text-decoration-line: underline;">${msgs.email[lang]}</span>`;
        }
      }

      function download(url) {
        if (url) {
          const link = document.createElement("a");
          link.href = url;
          link.click();
        }
      }

      if (window.Worker) {
        const puzzleWorker = new Worker("/assets/puzzle.js");
        fetch("/download")
          .then((response) => response.json())
          .then((data) => {
            puzzleWorker.postMessage(data.data);
            setTimer();
            puzzleWorker.onmessage = function (e) {
              setDownload(e.data);
            };
          })
          .catch((error) => console.error("Error:", error));
      } else {
       alert(msgs.workerError[lang]);
      }
    </script>
    <script type="text/javascript">
      (function(c,l,a,r,i,t,y){
          c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
          t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
          y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "m8rd47rp41");
  </script>
  </body>
</html>
